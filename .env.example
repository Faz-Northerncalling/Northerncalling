# Copy this file to .env.local for local development.
# In production, GitHub Actions injects this from repo Secrets during build.
# Get your key at https://web3forms.com — this is a per-form access key, not a private secret,
# but keeping it out of source lets you rotate it without a code change.
VITE_WEB3FORMS_KEY=your-web3forms-access-key-here
